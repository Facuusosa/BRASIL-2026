{
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(pip*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(node*)",
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(set PYTHONUTF8=1)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(type*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -Command \"[console]::Beep(880, 300); Start-Sleep -Milliseconds 100; [console]::Beep(1100, 200)\""
          }
        ]
      }
    ]
  }
}
